# Public DNS name routed to this server. Do not include http:// or a path.
NIVASA_DOMAIN=property.example.com

# Canonical externally reachable URL used in tenant invitation links.
NIVASA_PUBLIC_URL=https://property.example.com

# Required only until the first owner account is created.
# Generate with: bun run setup:token
NIVASA_INSTALL_TOKEN=replace-with-a-generated-token
