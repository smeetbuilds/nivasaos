# Public DNS name routed to this server. Do not include http:// or a path.
NIVASA_DOMAIN=property.example.com

# Canonical externally reachable URL used in tenant invitation links.
NIVASA_PUBLIC_URL=https://property.example.com

# Required only until the first owner account is created.
# Generate with either:
#   bun run setup:token
#   openssl rand -hex 32
NIVASA_INSTALL_TOKEN=replace-with-a-generated-token

# Optional backup safety bounds. Defaults shown: 8 GiB compressed/archive entry,
# 32 GiB expanded content, 100,000 entries, and a 1 MiB manifest.
NIVASA_BACKUP_MAX_ARCHIVE_BYTES=8589934592
NIVASA_BACKUP_MAX_EXPANDED_BYTES=34359738368
NIVASA_BACKUP_MAX_ENTRY_BYTES=8589934592
NIVASA_BACKUP_MAX_ENTRIES=100000
NIVASA_BACKUP_MAX_MANIFEST_BYTES=1048576
