{
  "name": "nivasaos",
  "version": "1.0.0",
  "private": true,
  "description": "Open-source, self-hosted modular property operations for residential rentals, PGs, hostels, student housing, staff accommodation, and commercial properties.",
  "license": "MIT",
  "scripts": {
    "dev": "bun --bun next dev",
    "build": "bun --bun next build",
    "start": "bun --bun next start",
    "verify:source": "bun run scripts/verify-source.js",
    "verify:schema": "bun run scripts/verify-schema.js",
    "verify:operations": "bun run scripts/verify-operations.js",
    "verify:ui": "bun run scripts/verify-ui.js",
    "verify:portal": "bun run scripts/verify-portal.js",
    "verify:handover": "bun run scripts/verify-handover.js",
    "verify:modules": "bun run scripts/verify-modules.js",
    "verify:verticals": "bun run scripts/verify-verticals.js",
    "verify:release": "bun run scripts/verify-release.js",
    "verify": "bun run verify:source && bun run verify:schema && bun run verify:operations && bun run verify:ui && bun run verify:portal && bun run verify:handover && bun run verify:modules && bun run verify:verticals && bun run verify:release",
    "gate": "bun run scripts/local-gate.js",
    "check": "bun run gate",
    "hooks:install": "bun run scripts/install-hooks.js",
    "backup": "bun run scripts/backup.js",
    "restore": "bun run scripts/restore.js"
  },
  "dependencies": {
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1"
  },
  "engines": { "bun": ">=1.3.0" },
  "repository": { "type": "git", "url": "https://github.com/smeetbuilds/nivasaos.git" },
  "homepage": "https://github.com/smeetbuilds/nivasaos#readme",
  "bugs": { "url": "https://github.com/smeetbuilds/nivasaos/issues" },
  "overrides": { "postcss": "8.5.19" }
}
